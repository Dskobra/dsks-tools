#!/usr/bin/bash

### Main launch script which sets some variables
device_menu(){
    echo "(1) Install packages              (2) Configure system"
    echo "(0) Exit"
    printf "Option: "
    read -r input

    case $input in

        1)
            "$HOME"/dsks-tools/bin/packages
            ;;

        2)
            "$HOME"/dsks-tools/bin/system
            ;;

        0)
            exit
            ;;

        *)
            echo -n "Unknown entry"
            echo ""
            device_menu
            ;;

        esac
        unset input
        device_menu
}

containers_menu(){
    echo "------------------"
    echo "|  Containers    |"
    echo "------------------"
    echo ""
    echo "(1) Create dev container               (2) Install apps"
    echo "(3) Create element container           (4) Install apps"
    echo "(0) Exit"
    printf "Option: "
    read -r input

    case $input in

        1)
            "$HOME"/dsks-tools/bin/create "tooling"
            ;;

        2)
            "$HOME"/dsks-tools/bin/containers "tooling"
            ;;

        3)
            "$HOME"/dsks-tools/bin/create "element" 
            ;;

        4)
            "$HOME"/dsks-tools/bin/containers "element"
            ;;
            
        0)
            exit
            ;;

        *)
            echo -n "Unknown entry"
            echo ""
            containers_menu
            ;;

        esac
        unset input
        containers_menu
}

gcache(){
    # discord from rpm/tarball and flatpak (user)
    rm -r ~/.config/discord/GPUCache/
    rm -r ~/.var/app/com.discordapp.Discord/config/discord/GPUCache/

    # wowup, raider.io and warcraft logs 3rd party world of warcraft
    # addons/services
    rm -r ~/.config/WowUpCf/GPUCache/
    rm -r ~/.config/RaiderIO/GPUCache/
    rm -r ~/.config/"Warcraft Logs Uploader"/GPUCache/
}

dsks_tools(){
    if [ "$1" == "--devices" ] || [ "$1" == "-d" ] || [ "$1" == "devices" ]
    then
        device_menu
    elif [ "$1" == "--containers" ] || [ "$1" == "-c" ] || [ "$1" == "containers" ]
    then
        containers_menu
    elif [ "$1" == "--gcache" ] || [ "$1" == "-g" ] || [ "$1" == "gcache" ]
    then
        gcache
    elif [ "$1" == "--update" ] || [ "$1" == "-u" ] || [ "$1" == "update" ]
    then
        cd "$HOME"/dsks-tools/ || exit
        git stash && git pull
    elif [ -z "$1" ]
    then
        echo "dtools: no option given"
        echo "Usage: dtools [OPTION]"
        echo "Try 'dtools --devices' or 'dtools --help' to see options"
    else
        echo "Invalid option: $1"
        echo ""
        dsks_tools_help
    fi
}

dsks_tools_help(){
    echo "dtools [args]"
    echo ""
    echo ""
    echo "Examples: "
    echo "  dtools --devices"
    echo "  dtools --containers"
    echo "  dtools --update"
    echo ""
    echo ""
    echo "Available arguments:"
    echo "  --devices, -d, devices          # opens menu for setting up my devices"
    echo "  --containers, -c, containers    # opens menu for creating containers"
    echo "  --gcache, -g, gcache            # cleans shader caches for select electron apps"
    echo "  --update, -u update             # updates these tools"
    echo ""
    echo ""
    echo "$COPYRIGHT"
    echo "Released under the MIT license"
}

export COPYRIGHT="Copyright (c) 2024-2026 Jordan Bottoms"
export DISTRO
export ARG_ONE
export ARG_TWO
DISTRO=$(source /etc/os-release ; echo $ID)
dsks_tools "$1"