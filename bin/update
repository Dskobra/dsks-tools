#!/usr/bin/bash

system(){
    if [ "$DISTRO" == "opensuse-tumbleweed" ]
    then
        sudo zypper -n dup --auto-agree-with-licenses
    elif [ "$DISTRO" == "almalinux" ]
    then
        sudo dnf update -y
    else
        echo ""
    fi
}

check_if_almalinux(){
    if [ "$DISTRO" == "almalinux" ]
    then
        echo "cockpit-files is available in repos."
    else
        cockpit_files
    fi
}

cockpit_files(){
    if [ -d "/usr/share/cockpit" ]; then
        cd "$HOME"/dsks-tools/temp || exit
        git clone https://github.com/cockpit-project/cockpit-files.git
        cd "cockpit-files" || exit
        make
        sudo make install
        rm -r -f "$HOME"/dsks-tools/temp/cockpit-files
    else
        echo "Cockpit not found. Not updating it."
    fi
}

update(){
    if [ "$1" == "cf" ] || [ "$1" == "-cf" ]
    then
        check_if_almalinux
    elif [ "$1" == "s" ] || [ "$1" == "-s" ]
    then
        system
    elif [ "$1" == "f" ] || [ "$1" == "-f" ]
    then
        flatpak update -y
        flatpak remove --unused -y
    elif [ -z "$1" ]
    then
        system
    else
        echo "Invalid option: $1"
        echo ""
        update_help
    fi
}

update_help(){
    echo "update [args]"
    echo ""
    echo ""
    echo "Examples: "
    echo "  update -f"
    echo "  update -s"
    echo ""
    echo ""
    echo "Available arguments:"
    echo "  cf, -cf                      # update cockpit-files."
    echo "  f,  -f                       # update flatpaks"
    echo "  s,  -s                       # update system packages"
}
DISTRO=$(source /etc/os-release ; echo $ID)
update "$1"
