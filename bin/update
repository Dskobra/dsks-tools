#!/usr/bin/bash

distro_commands(){
    if [ "$DISTRO" == "opensuse-tumbleweed" ]
    then
        sudo zypper -n dup --auto-agree-with-licenses
        build_cockpit_files
    elif [ "$DISTRO" == "almalinux" ]
    then
        sudo dnf update -y
    else
        echo ""
    fi
}

build_cockpit_files(){
    if [ -d "/usr/share/cockpit" ]; then
        cd "$HOME"/.local/share/dsks-tools/temp || exit
        git clone https://github.com/cockpit-project/cockpit-files.git
        cd "cockpit-files" || exit
        make
        sudo make install
        rm -r -f "$HOME"/.local/share/dsks-tools/temp/cockpit-files
    else
        echo "Cockpit not found. Not installing cockpit-files."
    fi
}

update(){
    if [ "$1" == "--apps" ] || [ "$1" == "-a" ] || [ "$1" == "apps" ]
    then
        flatpak update -y
        flatpak remove --unused -y
    elif [ "$1" == "--system" ] || [ "$1" == "-s" ] || [ "$1" == "system" ]
    then
        distro_commands
    elif [ "$1" == "--all" ] || [ "$1" == "-A" ] || [ "$1" == "all" ]
    then
        distro_commands
        flatpak update -y
        flatpak remove --unused -y
    elif [ -z "$1" ]
    then
        echo "update: no option given"
        echo "Usage: update [OPTION]"
        echo "Try 'update --system' or 'update --help' to see options"
    else
        echo "Invalid option: $1"
        echo ""
        update_help
    fi
}

update_help(){
    echo "update [args]"
    echo ""
    echo ""
    echo "Examples: "
    echo "  update --apps"
    echo "  update --system"
    echo "  update --all"
    echo ""
    echo ""
    echo "Available arguments:"
    echo "  --apps, -a, apps            # update flatpaks"
    echo "  --system, -s, system        # update rpm packages"
    echo "  --all, -A, all              # update all of the above"
}
DISTRO=$(source /etc/os-release ; echo $ID)
update "$1"
