#!/usr/bin/bash
update_boot_args(){
    BOOT_ARGS=$(cat /etc/kernel/cmdline)
    BOOT_ARGS="$BOOT_ARGS$DEVICE_BOOT_ARGS"
    echo "$BOOT_ARGS" | sudo tee /etc/kernel/cmdline > /dev/null

}

nvidia_drivers(){
    # main drivers
    sudo zypper -n install --auto-agree-with-licenses openSUSE-repos-Tumbleweed-NVIDIA

    sudo zypper al nvidia-open-driver-G06-signed-kmp-default
    sudo zypper al nvidia-open-driver-G07-signed-kmp-default

    sudo zypper al nvidia-open-driver-G06-signed-kmp-longterm
    sudo zypper al nvidia-open-driver-G07-signed-kmp-longterm

    sudo zypper al nvidia-open-driver-G06-signed-cuda-kmp-default
    sudo zypper al nvidia-open-driver-G07-signed-cuda-kmp-default

    # cuda drivers
    sudo zypper al nvidia-open-driver-G06-signed-cuda-kmp-longterm
    sudo zypper al nvidia-open-driver-G07-signed-cuda-kmp-longterm

    sudo zypper --gpg-auto-import-keys -n ref
    sudo zypper -n install --auto-agree-with-licenses dkms nvidia-settings nvidia-driver-G06-kmp-default \
    nvidia-driver-G06-kmp-longterm nvidia-userspace-meta-G06
}

desktop_specifics(){
    sudo zypper addrepo https://download.opensuse.org/repositories/home:codifryed/openSUSE_Tumbleweed/home:codifryed.repo
    sudo zypper --gpg-auto-import-keys -n ref
    sudo zypper -n install coolercontrol python-liquidctl-udev-rules lact 
    sudo systemctl enable --now coolercontrold
    sudo usermod -aG lact "$USER"
}

vscodium_repo(){
    sudo cp "$HOME"/dsks-tools/configs/vscodium.repo /etc/zypp/repos.d/vscodium.repo
    sudo chown root:root /etc/zypp/repos.d/vscodium.repo
    sudo zypper --gpg-auto-import-keys ref
}

general_packages(){
    cd "$HOME"/dsks-tools/temp || exit
    sudo zypper -n install --auto-agree-with-licenses  git git-gui git-cola gh distrobox cpu-x \
    remmina opi clamav virt-manager steam steam-devices podman setroubleshoot-server kdeconnect-kde \
    systemd-zram-service zram-generator ntsync-autoload codium zenity patterns-cockpit-client \
    cockpit-snapshots libvirt xfburn kate kate-plugins kleopatra partitionmanager mangohud \
    ShellCheck breeze6-wallpapers ucode-amd libvulkan_radeon libvulkan_radeon-32bit dbus-1-daemon


    sudo opi -n megasync
    sudo opi -n codecs

    cd "$HOME"/dsks-tools/temp || exit
    curl -L -o proton-mail.rpm $PROTON_MAIL
    curl -L -o proton-pass.rpm $PROTON_PASS
    curl -L -o proton-authenticator.rpm $PROTON_AUTH
    sudo zypper -n install --allow-unsigned-rpm ./*.rpm
    rm ./*.rpm

    # install nodejs
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.4/install.sh | bash
    source ~/.bashrc
    nvm install lts/*

    sudo flatpak install -y flathub com.github.tchx84.Flatseal io.podman_desktop.PodmanDesktop \
    io.missioncenter.MissionCenter it.mijorus.gearlever io.github.arunsivaramanneo.GPUViewer \
    org.gtkhash.gtkhash com.vysp3r.ProtonPlus com.obsproject.Studio org.raspberrypi.rpi-imager \
    com.discordapp.Discord com.usebottles.bottles org.kde.kaffeine \
    net.waterfox.waterfox org.freedesktop.Platform.VulkanLayer.MangoHud/x86_64/25.08 \
    org.kde.isoimagewriter im.riot.Riot io.github.kolunmi.Bazaar io.github.flattool.Warehouse \
    io.github.DenysMb.Kontainer

    sudo zypper -n rm lftp kmahjongg kmines kreversi ksudoku xscreensaver xscreensaver-data xterm \
    discover6 libyui-ncurses-pkg16 yast2*
    sudo zypper al libyui-ncurses-pkg16 yast2*
    sudo zypper -n dup
}

minipc_packages(){
    cd "$HOME"/dsks-tools/temp || exit
    sudo zypper -n install --auto-agree-with-licenses  git cpu-x opi clamav firewall-applet \
    setroubleshoot-server systemd-zram-service zram-generator nextcloud-desktop kdeconnect-kde \
    patterns-cockpit-client cockpit-snapshots xfburn kate kate-plugins zenity

    sudo opi -n megasync
    #sudo opi -n codecs

    cd "$HOME"/dsks-tools/temp || exit
    curl -L -o proton-pass.rpm $PROTON_PASS
    curl -L -o proton-authenticator.rpm $PROTON_AUTH
    sudo zypper -n install --allow-unsigned-rpm ./*.rpm
    rm ./*.rpm

    # install nodejs
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.4/install.sh | bash
    source ~/.bashrc
    nvm install lts/*

    sudo flatpak install -y flathub com.github.tchx84.Flatseal io.missioncenter.MissionCenter \
    io.github.arunsivaramanneo.GPUViewer org.gtkhash.gtkhash org.kde.kaffeine net.waterfox.waterfox \
    io.github.kolunmi.Bazaar io.github.flattool.Warehouse

    sudo zypper -n rm lftp kmahjongg kmines kreversi ksudoku xscreensaver xscreensaver-data xterm \
    yast2 yast2-core yast2-logs yast2 discover6
    sudo zypper -n dup
}

server_packages(){
    cd "$HOME"/dsks-tools/temp || exit
    sudo dnf install -y clamav clamav-freshclam firewall-applet kde-partitionmanager zenity

    DESKTOP_TYPE=$XDG_CURRENT_DESKTOP
    if [ "$DESKTOP_TYPE" == "KDE" ]
    then
        sudo dnf install -y kate kate-plugins kleopatra
    elif [ "$DESKTOP_TYPE" == "GNOME" ]
    then
        sudo dnf install -y gnome-tweaks dconf-editor
    else
        echo "$DESKTOP_TYPE is not supported."
    fi

    cd "$HOME"/dsks-tools/temp || exit
    curl -L -o proton-pass.rpm $PROTON_PASS
    curl -L -o proton-authenticator.rpm $PROTON_AUTH
    sudo zypper -n install --allow-unsigned-rpm ./*.rpm
    rm ./*.rpm
}

export PROTON_MAIL="https://proton.me/download/mail/linux/1.12.1/ProtonMail-desktop-beta.rpm"
export PROTON_PASS="https://proton.me/download/pass/linux/proton-pass-1.35.0-1.x86_64.rpm"
export PROTON_AUTH="https://proton.me/download/authenticator/linux/ProtonAuthenticator-1.1.4-1.x86_64.rpm"
DEVICE_BOOT_ARGS=""
DEVICE=$(uname -n)
if [ "$DEVICE" == "DesktopLnx" ]
then
    DEVICE_BOOT_ARGS=" amd_iommu=on iommu=pt amdgpu.ppfeaturemask=0xffffffff"
    update_boot_args
    vscodium_repo
    desktop_specifics
    general_packages
    zenity --warning --text="Reminder to restart terminal so it sees nodejs to install bash lsp"
elif [ "$DEVICE" == "LaptopLnx" ]
then
    DEVICE_BOOT_ARGS=" amd_iommu=on iommu=pt rd.driver.blacklist=nouveau,nova_core modprobe.blacklist=nouveau,nova_core"
    update_boot_args
    vscodium_repo    
    nvidia_drivers
    general_packages
    zenity --warning --text="Reminder to restart terminal so it sees nodejs to install bash lsp"
elif [ "$DEVICE" == "MINIPC" ]
then
    minipc_packages
elif [ "$DEVICE" == "SERVER" ]
then
    server_packages
    zenity --warning --text="Reminder to restart terminal so it sees nodejs to install bash lsp"
else
    echo "error"
fi
