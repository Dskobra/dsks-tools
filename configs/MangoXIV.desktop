[Desktop Entry]
Comment=Launch XIVLauncher /w mangohud
Exec=mangohud /usr/bin/flatpak run --branch=stable --arch=x86_64 --command=xivlauncher dev.goats.xivlauncher
Icon=dev.goats.xivlauncher
Name=MangoXIV
NoDisplay=false
Path=
PrefersNonDefaultGPU=false
StartupNotify=true
Terminal=false
TerminalOptions=
Type=Application
X-KDE-SubstituteUID=false
X-KDE-Username=
